# ── Experience: descriptions / achievements
msgid "Supporting entrepreneurs and SMEs with their digital marketing projects since 2022."
msgstr "Apoyando a Emprendedores y Pymes con sus proyectos de Marketing Digital desde 2022."

msgid "UX/UI & Web Optimization: design and improvement of user-centered interfaces, accessibility and conversion."
msgstr "UX/UI y Optimización Web: diseño y mejora de interfaces centradas en la experiencia del usuario, accesibilidad y conversión."

msgid "SEO & Digital Marketing: organic positioning strategies and content optimization in WordPress."
msgstr "SEO y Marketing Digital: implementación de estrategias de posicionamiento orgánico y optimización de contenido en WordPress."

msgid "Web Project Management: design and development coordination for SMEs, integrating analytics and A/B testing."
msgstr "Gestión de Proyectos Web: coordinación de diseño y desarrollo para PYMEs, integrando analítica y pruebas A/B para mejora continua."

msgid "Strategy, analysis and optimization of social media and Web for retail clients."
msgstr "Estrategia, análisis y optimización de RRSS y Web para clientes de retail."

msgid "Digital marketing project management and customer experience improvement in retail stores."
msgstr "Gestión de proyectos de marketing digital y mejora de la experiencia cliente en tiendas del sector retail."

msgid "Cross-departmental project follow-up and execution."
msgstr "Seguimiento y ejecución de proyectos en coordinación con el resto de los departamentos."

msgid "Content, design and signage proposals aligned with client and franchise branding to boost in-store sales."
msgstr "Propuesta de mejora en contenidos, diseño y cartelería según branding de clientes y franquicias, con el objetivo de aumentar ventas en tiendas."

msgid "Results analysis, reporting and process/cost optimization proposals."
msgstr "Análisis de resultados, informes y propuestas de optimización de procesos y costes."

msgid "Spreading valuable content for the leading Entrepreneurship radio show on Radio Intereconomía 95.1FM."
msgstr "Difundiendo contenido de valor para el programa de Radio líder en Emprendimiento, Cultura Emprende de Radio Intereconomía 95.1FM."

msgid "Show content editing."
msgstr "Edición de contenidos del programa."

msgid "Web design and social media management."
msgstr "Diseño Web y gestión de redes sociales."

msgid "Guest agenda management."
msgstr "Gestión de agenda de invitados."

msgid "Marketing and Communication project management for clients."
msgstr "Gestión de proyectos de Marketing y Comunicación para clientes."

msgid "Social media strategy and email marketing campaigns in Mailchimp and HubSpot."
msgstr "Planificación de estrategia de RRSS y campañas de email marketing en Mailchimp y HubSpot."

msgid "Advertising campaigns on Instagram and Facebook ads."
msgstr "Creación y desarrollo de campañas publicitarias en Instagram y Facebook ads."

msgid "Content management for Cultura Emprende Radio Intereconomía."
msgstr "Gestión de contenidos, patrocinios y canales de difusión del programa Cultura Emprende de Radio Intereconomía."

msgid "Signage layout and digital content proposals for clients."
msgstr "Maquetación de cartelería y creación de propuestas de contenidos digitales para clientes."

msgid "Project follow-up with agencies, suppliers and collaborators."
msgstr "Seguimiento de proyectos en comunicación con agencias, proveedores y colaboradores."

msgid "Analysis and reporting for management presentations."
msgstr "Análisis y creación de informes para la presentación de resultados con dirección."

msgid "Analysis and optimization of digital campaigns: social media, email marketing and basic SEO."
msgstr "Análisis y optimización de campañas digitales: redes sociales, email marketing y SEO básico."

